{
  "expo": {
    "name": "North Star Life",
    "slug": "north-star-life",
    "scheme": "north-star-life",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#04111A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.northstar.life"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#04111A"
      },
      "package": "com.northstar.life",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e843830e-3878-4234-969b-12fbbafb5796"
      }
    }
  }
}
